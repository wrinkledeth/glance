# MOODYLOTUS
ANTHROPIC_API_KEY=

# LLM provider: "anthropic", "ollama", or "web"
LLM_PROVIDER=ollama

# Ollama settings (only used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35B-A3B
# Seconds (or duration like "5m") Ollama keeps the model in VRAM after a
# request. 0 = unload immediately so the GPU is free for other work.
GLANCE_OLLAMA_KEEP_ALIVE=0

# Optional Instagram/TikTok first-frame OCR. Uses OLLAMA_HOST unless
# GLANCE_OCR_HOST is set.
GLANCE_OCR_MODEL=gemma4:e4b
GLANCE_OCR_HOST=http://localhost:11434

# Optional Instagram/TikTok speech-to-text fallback when yt-dlp returns no subtitles.
GLANCE_ASR_ENABLED=1
GLANCE_ASR_MODEL=large-v3-turbo
GLANCE_ASR_DEVICE=cuda
GLANCE_ASR_COMPUTE_TYPE=float16
GLANCE_ASR_TIMEOUT=180

# Web server (glance-web). Bind to a tailnet IP to expose only on Tailscale.
GLANCE_HOST=0.0.0.0
GLANCE_PORT=8765
