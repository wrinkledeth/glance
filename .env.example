ANTHROPIC_API_KEY=your-key-here

# LLM provider: "anthropic" (default) or "ollama"
LLM_PROVIDER=anthropic

# Ollama settings (only used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35B-A3B
# Seconds (or duration like "5m") Ollama keeps the model in VRAM after a
# request. 0 = unload immediately so the GPU is free for other work.
GLANCE_OLLAMA_KEEP_ALIVE=0

# Web server (glance-web). Defaults to localhost; front it with `tailscale
# serve --https=8443 http://127.0.0.1:8765` to expose on the tailnet over TLS.
GLANCE_HOST=127.0.0.1
GLANCE_PORT=8765
